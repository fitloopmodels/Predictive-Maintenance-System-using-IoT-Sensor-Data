class DataPreprocessor:
    """Handles data loading, cleaning, and preprocessing"""
    
    def __init__(self, scaler_type='standard'):
        self.scaler_type = scaler_type
        if scaler_type == 'standard':
            self.scaler = StandardScaler()
        else:
            self.scaler = MinMaxScaler()
        self.is_fitted = False
        self.remaining_sensors = None
    
    def load_cmapss_data(self, file_path):
        """
        Load NASA CMAPSS dataset
        Columns: unit_nr, time_cycles, op_setting_1, op_setting_2, 
                 op_setting_3, sensor_1...sensor_21
        """
        column_names = ['unit_nr', 'time_cycles'] + config.OP_SETTINGS + config.SENSOR_COLS
        df = pd.read_csv(file_path, sep='\s+', header=None, names=column_names)
        print(f"Loaded data: {df.shape[0]} rows, {df.shape[1]} columns")
        return df
    
    def add_remaining_useful_life(self, df):
        """Add RUL (Remaining Useful Life) column"""
        rul = pd.DataFrame(df.groupby('unit_nr')['time_cycles'].max()).reset_index()
        rul.columns = ['unit_nr', 'max_cycles']
        df = df.merge(rul, on=['unit_nr'])
        df['rul'] = df['max_cycles'] - df['time_cycles']
        df.drop('max_cycles', axis=1, inplace=True)
        return df
    
    def add_failure_label(self, df, threshold=None):
        """Add binary failure label based on RUL threshold"""
        if threshold is None:
            threshold = config.FAILURE_THRESHOLD
        df['failure_label'] = (df['rul'] <= threshold).astype(int)
        return df
    
    def remove_constant_sensors(self, df):
        """Remove sensors with constant values (no variation)"""
        constant_cols = []
        for col in config.SENSOR_COLS:
            if col in df.columns and df[col].nunique() == 1:
                constant_cols.append(col)
                print(f"Removing constant sensor: {col}")
        
        if constant_cols:
            df = df.drop(columns=constant_cols)
            self.remaining_sensors = [col for col in config.SENSOR_COLS 
                                      if col not in constant_cols]
        else:
            self.remaining_sensors = config.SENSOR_COLS
        
        return df
    
    def normalize_data(self, df, columns_to_normalize):
        """Normalize sensor and operational setting data"""
        if not self.is_fitted:
            df[columns_to_normalize] = self.scaler.fit_transform(df[columns_to_normalize])
            self.is_fitted = True
        else:
            df[columns_to_normalize] = self.scaler.transform(df[columns_to_normalize])
        return df
    
    def remove_outliers(self, df, columns, n_std=3):
        """Remove outliers using standard deviation method"""
        for col in columns:
            mean = df[col].mean()
            std = df[col].std()
            df = df[(df[col] <= mean + n_std * std) & 
                    (df[col] >= mean - n_std * std)]
        return df
    
    def save_scaler(self, path):
        """Save the fitted scaler"""
        joblib.dump(self.scaler, path)
    
    def load_scaler(self, path):
        """Load a fitted scaler"""
        self.scaler = joblib.load(path)
        self.is_fitted = True
    
    def create_sequences(self, data, labels, sequence_length):
        """Create sequences for LSTM model"""
        X, y = [], []
        for i in tqdm(range(len(data) - sequence_length), desc="Creating sequences"):
            X.append(data[i:(i + sequence_length)])
            y.append(labels[i + sequence_length])
        return np.array(X), np.array(y)
    
    def prepare_data_for_lstm(self, df, sequence_length, test_size=0.2):
        """Prepare data for LSTM model with train/test split"""
        # Get features and labels
        feature_cols = [col for col in df.columns 
                       if col not in ['unit_nr', 'time_cycles', 'rul', 'failure_label']]
        X = df[feature_cols].values
        y = df['failure_label'].values
        
        # Split by units to avoid data leakage
        unique_units = df['unit_nr'].unique()
        train_units, test_units = train_test_split(unique_units, test_size=test_size, 
                                                   random_state=config.RANDOM_STATE)
        
        train_mask = df['unit_nr'].isin(train_units)
        test_mask = df['unit_nr'].isin(test_units)
        
        X_train, y_train = X[train_mask], y[train_mask]
        X_test, y_test = X[test_mask], y[test_mask]
        
        # Create sequences
        X_train_seq, y_train_seq = self.create_sequences(X_train, y_train, sequence_length)
        X_test_seq, y_test_seq = self.create_sequences(X_test, y_test, sequence_length)
        
        # Split validation from training
        val_size = int(len(X_train_seq) * config.VAL_SIZE)
        X_val_seq, y_val_seq = X_train_seq[-val_size:], y_train_seq[-val_size:]
        X_train_seq, y_train_seq = X_train_seq[:-val_size], y_train_seq[:-val_size]
        
        return (X_train_seq, y_train_seq), (X_val_seq, y_val_seq), (X_test_seq, y_test_seq)

