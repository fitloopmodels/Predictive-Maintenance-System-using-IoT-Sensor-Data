class FeatureEngineer:
    """Engineers time-series and frequency domain features"""
    
    def __init__(self):
        self.feature_names = []
    
    def add_rolling_statistics(self, df, columns, window_sizes):
        """Add rolling statistics for time-series data"""
        for col in columns:
            for window in window_sizes:
                for stat in config.ROLLING_STATS:
                    feature_name = f'{col}_rolling_{stat}_w{window}'
                    if stat == 'mean':
                        df[feature_name] = df.groupby('unit_nr')[col].transform(
                            lambda x: x.rolling(window, min_periods=1).mean()
                        )
                    elif stat == 'std':
                        df[feature_name] = df.groupby('unit_nr')[col].transform(
                            lambda x: x.rolling(window, min_periods=1).std()
                        )
                    elif stat == 'min':
                        df[feature_name] = df.groupby('unit_nr')[col].transform(
                            lambda x: x.rolling(window, min_periods=1).min()
                        )
                    elif stat == 'max':
                        df[feature_name] = df.groupby('unit_nr')[col].transform(
                            lambda x: x.rolling(window, min_periods=1).max()
                        )
                    elif stat == 'skew':
                        df[feature_name] = df.groupby('unit_nr')[col].transform(
                            lambda x: x.rolling(window, min_periods=1).apply(skew)
                        )
                    
                    # Fill NaN values
                    df[feature_name].fillna(0, inplace=True)
                    self.feature_names.append(feature_name)
        
        return df
    
    def add_rate_of_change(self, df, columns):
        """Add rate of change (derivative) features"""
        for col in columns:
            feature_name = f'{col}_roc'
            df[feature_name] = df.groupby('unit_nr')[col].diff()
            df[feature_name].fillna(0, inplace=True)
            self.feature_names.append(feature_name)
        
        return df
    
    def add_fft_features(self, df, columns, n_components=10):
        """Add FFT features for frequency domain analysis"""
        for col in columns:
            fft_features = []
            for unit_id, group in df.groupby('unit_nr'):
                series = group[col].values
                if len(series) > 1:
                    fft_vals = np.abs(fft.fft(series))
                    top_fft = fft_vals[1:n_components+1]  # Skip DC component
                    
                    fft_dict = {'unit_nr': unit_id}
                    for i, val in enumerate(top_fft):
                        fft_dict[f'{col}_fft_{i}'] = val
                    fft_features.append(fft_dict)
            
            if fft_features:
                fft_df = pd.DataFrame(fft_features)
                df = df.merge(fft_df, on='unit_nr', how='left')
                
                for i in range(n_components):
                    feature_name = f'{col}_fft_{i}'
                    if feature_name in df.columns:
                        df[feature_name].fillna(0, inplace=True)
                        self.feature_names.append(feature_name)
        
        return df
    
    def add_spectral_energy(self, df, columns):
        """Add spectral energy features"""
        for col in columns:
            spectral_features = []
            for unit_id, group in df.groupby('unit_nr'):
                series = group[col].values
                if len(series) > 1:
                    freqs, psd = signal.periodogram(series, fs=1.0)
                    total_energy = np.sum(psd)
                    low_freq_idx = len(freqs) // 4
                    low_freq_energy = np.sum(psd[:low_freq_idx])
                    high_freq_idx = 3 * len(freqs) // 4
                    high_freq_energy = np.sum(psd[high_freq_idx:])
                    
                    spectral_features.append({
                        'unit_nr': unit_id,
                        f'{col}_total_energy': total_energy,
                        f'{col}_low_freq_energy': low_freq_energy,
                        f'{col}_high_freq_energy': high_freq_energy,
                        f'{col}_energy_ratio': low_freq_energy / (total_energy + 1e-6)
                    })
            
            if spectral_features:
                energy_df = pd.DataFrame(spectral_features)
                df = df.merge(energy_df, on='unit_nr', how='left')
                
                for suffix in ['total_energy', 'low_freq_energy', 'high_freq_energy', 'energy_ratio']:
                    feature_name = f'{col}_{suffix}'
                    if feature_name in df.columns:
                        df[feature_name].fillna(0, inplace=True)
                        self.feature_names.append(feature_name)
        
        return df
    
    def add_statistical_features(self, df, columns):
        """Add statistical features for each unit"""
        for col in columns:
            stats = []
            for unit_id, group in df.groupby('unit_nr'):
                series = group[col].values
                stats.append({
                    'unit_nr': unit_id,
                    f'{col}_mean': np.mean(series),
                    f'{col}_std': np.std(series),
                    f'{col}_skew': skew(series) if len(series) > 1 else 0,
                    f'{col}_kurtosis': kurtosis(series) if len(series) > 1 else 0,
                    f'{col}_min': np.min(series),
                    f'{col}_max': np.max(series),
                    f'{col}_range': np.max(series) - np.min(series)
                })
            
            stats_df = pd.DataFrame(stats)
            df = df.merge(stats_df, on='unit_nr', how='left')
            
            for suffix in ['mean', 'std', 'skew', 'kurtosis', 'min', 'max', 'range']:
                feature_name = f'{col}_{suffix}'
                if feature_name in df.columns:
                    df[feature_name].fillna(0, inplace=True)
                    self.feature_names.append(feature_name)
        
        return df
    
    def engineer_all_features(self, df, sensor_cols, op_cols):
        """Apply all feature engineering techniques"""
        all_cols = sensor_cols + op_cols
        
        print("Adding rolling statistics...")
        df = self.add_rolling_statistics(df, all_cols, config.WINDOW_SIZES)
        
        print("Adding rate of change features...")
        df = self.add_rate_of_change(df, all_cols)
        
        print("Adding FFT features...")
        df = self.add_fft_features(df, all_cols, config.FFT_COMPONENTS)
        
        print("Adding spectral energy features...")
        df = self.add_spectral_energy(df, all_cols)
        
        print("Adding statistical features...")
        df = self.add_statistical_features(df, all_cols)
        
        print(f"Total features engineered: {len(self.feature_names)}")
        return df

