    # Create directories
    for dir_path in [RAW_DATA_DIR, PROCESSED_DATA_DIR, MODELS_DIR, REPORTS_DIR]:
        os.makedirs(dir_path, exist_ok=True)
    
    # Data parameters
    SENSOR_COLS = [f'sensor_{i}' for i in range(1, 22)]  # 21 sensors
    OP_SETTINGS = ['op_setting_1', 'op_setting_2', 'op_setting_3']
    
    # Feature engineering parameters
    WINDOW_SIZES = [5, 10, 15, 20]
    FFT_COMPONENTS = 10
    ROLLING_STATS = ['mean', 'std', 'min', 'max', 'skew']
    
    # Model parameters
    RANDOM_STATE = 42
    TEST_SIZE = 0.2
    VAL_SIZE = 0.1
    
    # LSTM parameters
    LSTM_SEQUENCE_LENGTH = 50
    LSTM_BATCH_SIZE = 64
    LSTM_EPOCHS = 100
    LSTM_UNITS = [64, 32]
    
    # Failure threshold (cycles before failure)
    FAILURE_THRESHOLD = 30

config = Config()

